{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--executable-path=/home/chicks/.cache/puppeteer-browsers/chrome/linux-147.0.7727.50/chrome-linux64/chrome"
      ]
    },
    "honeycomb": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.honeycomb.io/mcp",
        "--auth-timeout",
        "60"
      ],
      "enabled": true,
      "timeout": 120000
    }
  }
}
